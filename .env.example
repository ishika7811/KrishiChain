# KrishiChain Environment Variables
# Copy this file to .env.local and fill in your actual API keys

# ── Google Cloud / Firebase ──
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# ── Gemini API ──
VITE_GEMINI_API_KEY=your_gemini_api_key
# Model: gemini-2.0-flash (vision + text)
# Endpoint: https://generativelanguage.googleapis.com/v1beta/models/gemini-2.0-flash:generateContent

# ── Google Maps ──
VITE_MAPS_API_KEY=your_maps_api_key
# Required APIs to enable in Cloud Console:
#   Maps JavaScript API
#   Routes API
#   Distance Matrix API
#   Places API
#   Geocoding API

# ── Vertex AI ──
VITE_GCP_PROJECT_ID=your_gcp_project_id
VITE_VERTEX_LOCATION=us-central1
# Endpoint: https://LOCATION-aiplatform.googleapis.com/v1/projects/PROJECT/locations/LOCATION/endpoints/ENDPOINT:predict

# ── Translation API ──
VITE_TRANSLATE_API_KEY=your_translate_api_key

# ── Text-to-Speech API ──
VITE_TTS_API_KEY=your_tts_api_key

# ── External Data (Free — no key needed) ──
# Open-Meteo weather: https://api.open-meteo.com/v1/forecast
# NASA NDVI via Earth Engine: https://earthengine.googleapis.com
# Agmarknet prices: https://agmarknet.gov.in/SearchCommodity.aspx (CSV download)
